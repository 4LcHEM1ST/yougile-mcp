{
  "name": "yougile-mcp",
  "version": "1.1.0",
  "description": "A CLI and MCP server for YouGile",
  "main": "yougile.js",
  "bin": {
    "yougile": "./bin/yougile.cjs"
  },
  "type": "module",
  "scripts": {
    "start": "node yougile.js",
    "build": "tsc",
    "cli": "node build/cli.js",
    "dev": "nodemon --watch src --ext ts --exec \"npm run build\" && node build/index.js",
    "serve": "npm run build && node build/index.js"
  },
  "keywords": [
    "yougile",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "axios": "^1.13.5",
    "dotenv": "^17.3.1",
    "yargs": "^17.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "nodemon": "^3.1.7",
    "prettier": "^3.5.3",
    "typescript": "^5.5.4"
  }
}
