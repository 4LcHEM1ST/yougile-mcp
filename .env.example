# ---------------------------------------------------------------------------
# YouGile MCP server configuration
# Copy this file to `.env` and fill in the values. Do NOT commit `.env`.
# ---------------------------------------------------------------------------

# Shared YouGile API key (Bearer). All authenticated users act through this key.
# Get it from the YouGile configurator or POST https://yougile.com/api-v2/auth/keys
YOUGILE_API_KEY=

# Optional: override the YouGile API base URL (defaults to https://yougile.com/api-v2/)
# YOUGILE_API_HOST_URL=https://yougile.com/api-v2/

# Optional: write request/response debug logs to ./yougile-mcp-debug.log
# YOUGILE_DEBUG=0

# ---------------------------------------------------------------------------
# HTTP / OAuth deployment (only needed for `npm run serve:http`)
# ---------------------------------------------------------------------------

# TCP port to listen on (default 3000)
MCP_PORT=3000

# Public base URL of THIS server, as reached by clients (used as the OAuth
# "resource" identifier in protected-resource metadata). No trailing slash.
MCP_PUBLIC_URL=https://mcp.example.com

# Google OAuth client ID. Incoming tokens must have this as their audience (`aud`).
# Create one at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Optional: restrict access to a single Google Workspace domain (the `hd` claim).
# GOOGLE_ALLOWED_DOMAIN=example.com

# Optional: comma-separated allowlist of permitted user emails.
# Leave empty to allow any verified Google account (subject to the domain check).
# GOOGLE_ALLOWED_EMAILS=alice@example.com,bob@example.com

# ---------------------------------------------------------------------------
# Docker Compose (Caddy reverse proxy + TLS)
# ---------------------------------------------------------------------------

# Public domain that points (DNS A/AAAA) at this server. Caddy gets a Let's
# Encrypt certificate for it. With compose, MCP_PUBLIC_URL is derived as
# https://${MCP_DOMAIN}, so you do not need to set MCP_PUBLIC_URL separately.
MCP_DOMAIN=mcp.example.com

# Email for Let's Encrypt registration / expiry notices.
ACME_EMAIL=admin@example.com
