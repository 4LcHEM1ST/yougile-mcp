# ---------------------------------------------------------------------------
# YouGile MCP server configuration
# Copy this file to `.env` and fill in the values. Do NOT commit `.env`.
# ---------------------------------------------------------------------------

# Shared YouGile API key (Bearer). All authenticated users act through this key.
# Get it from the YouGile configurator or POST https://yougile.com/api-v2/auth/keys
YOUGILE_API_KEY=

# Optional: override the YouGile API base URL (defaults to https://yougile.com/api-v2/)
# YOUGILE_API_HOST_URL=https://yougile.com/api-v2/

# Optional: write request/response debug logs to ./yougile-mcp-debug.log
# YOUGILE_DEBUG=0

# ---------------------------------------------------------------------------
# HTTP / OAuth deployment (only needed for `npm run serve:http`)
# ---------------------------------------------------------------------------

# Listen address (default 0.0.0.0). Use 127.0.0.1 if behind a reverse proxy.
# MCP_HOST=0.0.0.0

# TCP port to listen on (default 3000)
MCP_PORT=3000

# Public HTTPS URL of THIS server, as reached by clients. No trailing slash.
# This is also the URL you enter into Claude.ai as the MCP connector URL.
MCP_PUBLIC_URL=https://mcp.example.com

# ---------------------------------------------------------------------------
# Google OAuth 2.0 credentials
# Create a Web Application credential at https://console.cloud.google.com/apis/credentials
# Add this Authorized redirect URI: https://mcp.example.com/auth/callback
# ---------------------------------------------------------------------------

# Client ID (public identifier, shown in the consent screen)
GOOGLE_CLIENT_ID=

# Client Secret (keep private — used server-side to exchange the authorization code)
GOOGLE_CLIENT_SECRET=

# Access control is REQUIRED: set GOOGLE_ALLOWED_EMAILS and/or GOOGLE_ALLOWED_DOMAIN.
# If neither is set, the server refuses to start (it would otherwise let any verified
# Google account reach the shared YouGile workspace).

# Restrict access to a single Google Workspace domain (verified `hd` claim).
# GOOGLE_ALLOWED_DOMAIN=example.com

# Comma-separated allowlist of permitted user emails.
# GOOGLE_ALLOWED_EMAILS=alice@example.com,bob@example.com

# ---------------------------------------------------------------------------
# Docker Compose (Caddy reverse proxy + TLS)
# ---------------------------------------------------------------------------

# Public domain that points (DNS A/AAAA) at this server. Caddy gets a Let's
# Encrypt certificate for it. With compose, MCP_PUBLIC_URL is derived as
# https://${MCP_DOMAIN}, so you do not need to set MCP_PUBLIC_URL separately.
MCP_DOMAIN=mcp.example.com

# Email for Let's Encrypt registration / expiry notices.
ACME_EMAIL=admin@example.com
